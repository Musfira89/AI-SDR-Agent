# Copy this file to ".env" and fill in your free API keys.

# Google Gemini (free tier) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Serper.dev (free tier, 2500 queries) — https://serper.dev
SERPER_API_KEY=

# Optional: change the Gemini model if you like (default is a fast, free model)
GEMINI_MODEL=gemini-2.0-flash
