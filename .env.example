# Copy this file to ".env" and fill in your free API keys.
# NEVER commit the real .env (it is already in .gitignore) and never share keys in chat.

# Groq (free tier) — create a key at https://console.groq.com/keys
GROQ_API_KEY=

# Serper.dev (free tier, 2500 queries) — https://serper.dev
SERPER_API_KEY=

# Model on Groq. Recommended: llama-3.3-70b-versatile
# Fast fallback if you hit rate limits: llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile
